{
  "manifest_version": 3,
  "name": "Kowalski - FII Report Analyzer",
  "version": "0.1.0",
  "description": "Transforma relatórios de FIIs do FNET/CVM em dashboards modernos com vacância, DY, rentabilidade e mais.",
  "homepage_url": "https://github.com/geeksilva97/kowalski",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://fnet.bmfbovespa.com.br/fnet/publico/exibirDocumento*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
